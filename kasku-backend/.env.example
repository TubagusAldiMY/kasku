# ==============================================================
# KasKu SaaS — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# NOTE: Passwords must not contain single-quotes (').
# ==============================================================

# --------------------------------------------------------------
# PostgreSQL — Superuser (used by Docker init and migrations)
# --------------------------------------------------------------
POSTGRES_SUPERUSER_PASS=change_this_superuser_pass

# --------------------------------------------------------------
# PostgreSQL — Service Users
# Each service uses its own DB user (least privilege).
# --------------------------------------------------------------
KASKU_AUTH_DB_PASS=change_this_auth_pass
KASKU_BILLING_DB_PASS=change_this_billing_pass
KASKU_FINANCE_DB_PASS=change_this_finance_pass
KASKU_TRANSACTION_DB_PASS=change_this_transaction_pass
KASKU_INVESTMENT_DB_PASS=change_this_investment_pass
KASKU_SYNC_DB_PASS=change_this_sync_pass
KASKU_USER_DB_PASS=change_this_user_pass
KASKU_PRICE_DB_PASS=change_this_price_pass
KASKU_NOTIFICATION_DB_PASS=change_this_notification_pass
KASKU_ADMIN_DB_PASS=change_this_admin_pass
KASKU_ADMIN_READ_DB_PASS=change_this_admin_read_pass

# --------------------------------------------------------------
# Redis
# --------------------------------------------------------------
REDIS_PASSWORD=change_this_redis_pass

# --------------------------------------------------------------
# RabbitMQ
# --------------------------------------------------------------
RABBITMQ_USER=kasku_mq_user
RABBITMQ_PASS=change_this_rabbitmq_pass

# --------------------------------------------------------------
# Traefik / Let's Encrypt (production only)
# --------------------------------------------------------------
ACME_EMAIL=admin@tubsamy.tech
APP_DOMAIN=app.kasku.id

# --------------------------------------------------------------
# auth-service
# Generate RSA-4096 key pair:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w0 private.pem  → JWT_PRIVATE_KEY
#   base64 -w0 public.pem   → JWT_PUBLIC_KEY
# --------------------------------------------------------------
JWT_PRIVATE_KEY=<base64url-encoded RSA-4096 PEM private key>
JWT_PUBLIC_KEY=<base64url-encoded RSA-4096 PEM public key>
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h
ARGON2_TIME=3
ARGON2_MEMORY_KB=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_DURATION=15m

# Rate limiting (auth-service, Redis sliding window)
# Set RATE_LIMIT_ENABLED=false untuk dev kalau ingin disable
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REGISTER_PER_MIN=10
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_FORGOT_IP_PER_MIN=5
RATE_LIMIT_FORGOT_EMAIL_PER_HOUR=3
RATE_LIMIT_RESEND_EMAIL_PER_HOUR=3
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_EMAIL_WINDOW=1h

# Token cleanup background job (retention)
# Hapus refresh_tokens >30d expired, email_verifications/password_reset/outbox >7d.
# Set CLEANUP_DRY_RUN=true di first deploy untuk validasi count via log dulu.
CLEANUP_ENABLED=true
CLEANUP_INTERVAL=1h
CLEANUP_DRY_RUN=false

# Shared secret untuk gRPC internal RPC sensitif (RevokeUserTokens dari admin-service).
# Kosongkan di dev — server akan log warning. WAJIB di prod.
# Generate: openssl rand -hex 32
INTERNAL_GRPC_SECRET=

# --------------------------------------------------------------
# api-gateway
# --------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://app.kasku.id
RATE_LIMIT_REDIS_KEY_PREFIX=kasku:rl:

# --------------------------------------------------------------
# billing-service
# Get from Midtrans dashboard: https://dashboard.midtrans.com
# --------------------------------------------------------------
MIDTRANS_SERVER_KEY=SB-Mid-server-CHANGE_THIS
MIDTRANS_CLIENT_KEY=SB-Mid-client-CHANGE_THIS
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/v1
SUBSCRIPTION_EXPIRY_WARNING_DAYS=3

# --------------------------------------------------------------
# price-service (Rust)
# CoinGecko API key: https://www.coingecko.com/en/api
# metals.live API key: https://metals.live
# --------------------------------------------------------------
COINGECKO_API_KEY=
PRICE_CACHE_TTL_SECONDS=900
EXTERNAL_REQUEST_TIMEOUT_SECONDS=10
GOLD_USD_IDR_RATE=16000
METALS_LIVE_URL=https://api.metals.live/v1/spot/gold
PRICE_SCHEDULER_SYMBOLS=bitcoin,ethereum,XAU
PRICE_SCHEDULER_INTERVAL_SECONDS=900

# --------------------------------------------------------------
# notification-service
# SMTP or SendGrid. For SendGrid: SMTP_HOST=smtp.sendgrid.net,
# SMTP_USERNAME=apikey, SMTP_PASSWORD=<sendgrid_api_key>
# --------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change_this
SMTP_PASS=change_this
SMTP_FROM=noreply@kasku.id
SMTP_FROM_NAME=KasKu
APP_BASE_URL=https://app.kasku.id

# --------------------------------------------------------------
# admin-service
# Use a strong random secret, separate from JWT keys.
# openssl rand -hex 32
# --------------------------------------------------------------
ADMIN_JWT_SECRET=change_this_admin_jwt_secret
ADMIN_JWT_TTL=8h
# Bootstrap admin pertama — di-seed otomatis kalau tabel admin_users kosong.
# Setelah pertama login, admin disarankan untuk mengubah password sendiri.
ADMIN_BOOTSTRAP_USERNAME=superadmin
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe-Strong-Passw0rd!

# --------------------------------------------------------------
# Observability profile (internal/admin network only)
# --------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_pass

# --------------------------------------------------------------
# Global
# --------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
