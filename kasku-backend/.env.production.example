# ============================================================
# KasKu Production Environment Variables
# Salin file ini ke .env, isi nilainya, lalu jalankan:
#   docker compose -f docker-compose.yml up -d
#
# PERINGATAN: Jangan commit .env ke version control.
# ============================================================

# ── Traefik / TLS ───────────────────────────────────────────
ACME_EMAIL=admin@yourdomain.com

# ── PostgreSQL ──────────────────────────────────────────────
# Superuser untuk inisialisasi database (hanya dibaca saat pertama kali init)
POSTGRES_SUPERUSER_PASS=change_me_strong_password_32chars

# Password per service (least-privilege users)
KASKU_AUTH_DB_PASS=change_me_auth_pass
KASKU_USER_DB_PASS=change_me_user_pass
KASKU_BILLING_DB_PASS=change_me_billing_pass
KASKU_FINANCE_DB_PASS=change_me_finance_pass
KASKU_TRANSACTION_DB_PASS=change_me_transaction_pass
KASKU_INVESTMENT_DB_PASS=change_me_investment_pass
KASKU_PRICE_DB_PASS=change_me_price_pass
KASKU_SYNC_DB_PASS=change_me_sync_pass
KASKU_NOTIFICATION_DB_PASS=change_me_notification_pass
KASKU_ADMIN_DB_PASS=change_me_admin_pass

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_pass

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_USER=kasku_admin
RABBITMQ_PASS=change_me_rabbitmq_pass

# ── JWT RS256 (auth-service signing, api-gateway verification) ──
# Generate RSA-4096 key pair:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Kemudian set sebagai single-line dengan \n escaped:
#   JWT_PRIVATE_KEY=$(awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem)
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----

# ── Admin Service ───────────────────────────────────────────
ADMIN_JWT_SECRET=change_me_min_32_chars_hs256_secret
ADMIN_JWT_TTL=8h
ADMIN_BOOTSTRAP_USERNAME=superadmin
ADMIN_BOOTSTRAP_PASSWORD=change_me_strong_admin_password

# ── Internal gRPC Secret ────────────────────────────────────
INTERNAL_GRPC_SECRET=change_me_grpc_secret

# ── Argon2id Parameters (OWASP recommended) ─────────────────
ARGON2_TIME=3
ARGON2_MEMORY_KB=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32

# ── SMTP (notification-service) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=KasKu <noreply@yourdomain.com>
APP_BASE_URL=https://yourdomain.com

# ── Payment Gateway (Midtrans) ──────────────────────────────
# Set di billing-service via docker-compose.yml env override (bukan via .env global)
# MIDTRANS_SERVER_KEY dan MIDTRANS_CLIENT_KEY tidak ada di docker-compose.yml global —
# tambahkan langsung di environment billing-service jika diperlukan.

# ── CoinGecko API (price-service) ───────────────────────────
COINGECKO_API_KEY=your_coingecko_api_key
PRICE_SCHEDULER_INTERVAL_SECONDS=300
PRICE_CACHE_TTL_SECONDS=600
PRICE_SCHEDULER_SYMBOLS=bitcoin,ethereum,binancecoin,solana,cardano

# ── Gold/USD-IDR fallback (price-service) ───────────────────
METALS_LIVE_URL=https://metals-api.com/api/latest
GOLD_USD_IDR_RATE=16000
EXTERNAL_REQUEST_TIMEOUT_SECONDS=10

# ── Application ─────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info

# ── Grafana Monitoring ──────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_pass
