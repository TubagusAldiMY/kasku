# ============================================================
# KasKu Production Environment Variables
# Salin file ini ke .env, isi nilainya, lalu jalankan:
#   docker compose -f docker-compose.yml up -d
#
# PERINGATAN: Jangan commit .env ke version control.
# CATATAN: Nilai ini juga harus di-set sebagai GitHub Secrets
#          agar deploy.yml bisa generate .env otomatis.
# ============================================================

# ── Traefik / TLS ───────────────────────────────────────────
ACME_EMAIL=admin@tubsamy.tech
APP_DOMAIN=app.kasku.id
# Domain publik api-gateway (digunakan Traefik routing rule)
KASKU_API_DOMAIN=api.kasku.id

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_SUPERUSER_PASS=change_me_strong_password_32chars

# Password per service (least-privilege users)
KASKU_AUTH_DB_PASS=change_me_auth_pass
KASKU_USER_DB_PASS=change_me_user_pass
KASKU_BILLING_DB_PASS=change_me_billing_pass
KASKU_FINANCE_DB_PASS=change_me_finance_pass
KASKU_TRANSACTION_DB_PASS=change_me_transaction_pass
KASKU_INVESTMENT_DB_PASS=change_me_investment_pass
KASKU_PRICE_DB_PASS=change_me_price_pass
KASKU_SYNC_DB_PASS=change_me_sync_pass
KASKU_NOTIFICATION_DB_PASS=change_me_notification_pass
KASKU_ADMIN_DB_PASS=change_me_admin_pass
KASKU_ADMIN_READ_DB_PASS=change_me_admin_read_pass

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_pass

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_USER=kasku_mq_user
RABBITMQ_PASS=change_me_rabbitmq_pass

# ── JWT RS256 (auth-service signing, api-gateway verification) ──
# Generate RSA-4096 key pair lalu base64-encode (single-line):
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w0 private.pem  → JWT_PRIVATE_KEY
#   base64 -w0 public.pem   → JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=<base64-encoded RSA-4096 PEM private key>
JWT_PUBLIC_KEY=<base64-encoded RSA-4096 PEM public key>
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

# ── Argon2id ────────────────────────────────────────────────
ARGON2_TIME=3
ARGON2_MEMORY_KB=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_DURATION=15m

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REGISTER_PER_MIN=10
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_FORGOT_IP_PER_MIN=5
RATE_LIMIT_FORGOT_EMAIL_PER_HOUR=3
RATE_LIMIT_RESEND_EMAIL_PER_HOUR=3
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_EMAIL_WINDOW=1h
RATE_LIMIT_SYNC_PER_MIN=60
RATE_LIMIT_REDIS_KEY_PREFIX=kasku:rl:

# ── Token Cleanup ───────────────────────────────────────────
CLEANUP_ENABLED=true
CLEANUP_INTERVAL=1h
CLEANUP_DRY_RUN=false

# ── Internal gRPC Secret ────────────────────────────────────
# Generate: openssl rand -hex 32
INTERNAL_GRPC_SECRET=change_me_grpc_secret

# ── api-gateway ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.kasku.id

# ── billing-service — Payment Orchestrator ──────────────────
# API key dari portal https://api-payment.roemahprogram.com
# Gunakan sk_test_... untuk staging, sk_live_... untuk production
# KASKU_PAYMENT_CALLBACK_BASE_URL: URL publik API backend KasKu
#   yang bisa dijangkau orchestrator untuk kirim webhook.
#   Contoh: https://api.kasku.app
KASKU_PAYMENT_ORCHESTRATOR_API_KEY=sk_live_CHANGE_THIS_FROM_PORTAL
KASKU_PAYMENT_WEBHOOK_SECRET=CHANGE_THIS_FROM_PORTAL_WEBHOOK_SECRET_REGENERATE
KASKU_PAYMENT_CALLBACK_BASE_URL=https://api.kasku.app
SUBSCRIPTION_EXPIRY_WARNING_DAYS=3

# ── Admin Service ───────────────────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_min_32_chars_hs256_secret
ADMIN_JWT_TTL=8h
ADMIN_BOOTSTRAP_USERNAME=superadmin
ADMIN_BOOTSTRAP_PASSWORD=change_me_strong_admin_password

# ── SMTP (notification-service) ─────────────────────────────
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_USER=your@gmail.com,
#        SMTP_PASS=<App Password dari Google Account>
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey,
#           SMTP_PASS=<SendGrid API Key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@kasku.id
SMTP_PASS=your_app_specific_password
SMTP_FROM=noreply@kasku.id
SMTP_FROM_NAME=KasKu
APP_BASE_URL=https://app.kasku.id

# ── CoinGecko API (price-service) ───────────────────────────
# https://www.coingecko.com/en/api — free tier cukup untuk production
COINGECKO_API_KEY=your_coingecko_api_key
PRICE_CACHE_TTL_SECONDS=900
EXTERNAL_REQUEST_TIMEOUT_SECONDS=10
GOLD_USD_IDR_RATE=16000
METALS_LIVE_URL=https://api.metals.live/v1/spot/gold
PRICE_SCHEDULER_SYMBOLS=bitcoin,ethereum,XAU
PRICE_SCHEDULER_INTERVAL_SECONDS=900

# ── Application ─────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=warn

# ── Grafana Monitoring ──────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_pass

# ── S3 Backup ───────────────────────────────────────────────
BACKUP_BUCKET=kasku-backups
BACKUP_PASSPHRASE=change_me_backup_passphrase_gpg
AWS_ACCESS_KEY_ID=change_me_aws_key
AWS_SECRET_ACCESS_KEY=change_me_aws_secret
AWS_DEFAULT_REGION=ap-southeast-1
