# admin-service — sample local dev env
# Copy ke .env (gitignored) dan sesuaikan untuk lokal kalau perlu.
# Untuk Docker, .env utama di kasku-backend/ yang dipakai (override.yml + env_file).

SERVER_PORT=8090
APP_ENV=development
LOG_LEVEL=info
SERVICE_VERSION=1.0.0

# DSN postgres ke 3 database. Pakai user kasku_*_svc karena admin-service
# membonceng credential service pemilik untuk write cross-DB (suspend / override).
# Lihat README.md untuk trade-off-nya.
POSTGRES_ADMIN_DSN=postgres://kasku_admin_svc:change_this_admin_pass@localhost:5432/kasku_admin?sslmode=disable
POSTGRES_AUTH_ADMIN_DSN=postgres://kasku_auth_svc:change_this_auth_pass@localhost:5432/kasku_auth?sslmode=disable
POSTGRES_BILLING_ADMIN_DSN=postgres://kasku_billing_svc:change_this_billing_pass@localhost:5432/kasku_billing?sslmode=disable

# Redis untuk blacklist JWT (jti namespace: "admin_jti:")
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=change_this_redis_pass

# Admin JWT HS256 — TERPISAH dari user JWT RS256.
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=change_this_admin_jwt_secret
ADMIN_JWT_TTL=8h

# Bootstrap admin pertama — di-seed sekali kalau admin_users masih kosong.
# Setelah login pertama, admin disarankan ubah password sendiri.
ADMIN_BOOTSTRAP_USERNAME=superadmin
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe-Strong-Passw0rd!

# Argon2id parameters — samakan dengan auth-service.
ARGON2_TIME=3
ARGON2_MEMORY_KB=65536
ARGON2_THREADS=4
ARGON2_KEY_LENGTH=32
