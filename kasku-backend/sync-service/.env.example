# sync-service — sample local dev env
# Copy ke .env (gitignored) dan sesuaikan untuk lokal kalau perlu.
# Untuk Docker, override.yml + .env utama di kasku-backend/ yang dipakai.

HTTP_PORT=8088
APP_ENV=development
LOG_LEVEL=info,sync_service=debug,sqlx=warn

# DSN postgres ke kasku_finance — gunakan user kasku_sync_svc.
# Password disinkron dengan KASKU_SYNC_DB_PASS di .env utama kasku-backend.
DATABASE_URL=postgres://kasku_sync_svc:change_this_sync_pass@localhost:5432/kasku_finance?sslmode=disable

# gRPC endpoint owning service.
# Untuk dev di host: ganti localhost dengan port host-mapping yang aktif.
# Di Docker network: gunakan kasku-finance-service:9084 dst.
FINANCE_SERVICE_GRPC_ADDR=http://localhost:9084
TRANSACTION_SERVICE_GRPC_ADDR=http://localhost:9085
INVESTMENT_SERVICE_GRPC_ADDR=http://localhost:9086

# Hard timeout per RPC call (ms). Drop ke 1000-2000 di staging untuk surfing
# slow-upstream issue lebih cepat. Production default 5000.
GRPC_REQUEST_TIMEOUT_MS=5000
